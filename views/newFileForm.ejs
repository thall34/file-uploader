<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title><%= title %></title>
    </head>
    <body>
        <form action="/file/new/<%= id %>" method="POST" enctype="multipart/form-data">
            <h1><%= title %></h1>
            <label for="file">File: (max file size 5mb and must be .jpg, .png or .webp)</label>
            <input type="file" name="file" id="file">
            <button type="submit">Upload File</button>
        </form>
    </body>
</html>